# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control (it may contain
# environment-specific values you don't want in git history).

project_id = "your-gcp-project-id"
region     = "us-central1"

# Optional overrides (defaults are fine for most deployments)
# bq_location                  = "US"
# pii_bucket_name              = ""                       # defaults to "<project_id>-loan-origination-pii"
# audit_dataset_id             = "bankvault_audit"
# audit_table_id               = "access_grants"
# platform_logs_dataset_id     = "bankvault_platform_logs"
# grant_function_name          = "bankvault-grant-access"
# revoke_function_name         = "bankvault-revoke-access"
# revocation_topic_name        = "bankvault-revocation-trigger"
# revocation_schedule          = "*/5 * * * *"
# revocation_schedule_timezone = "Etc/UTC"
# max_grant_duration_minutes   = 240
# allowed_requester_domain     = "bank.example.com"        # empty string disables the check
# grant_function_ingress       = "ALLOW_INTERNAL_ONLY"

# Demo-only: provisions one Terraform-managed conditional binding so
# `terraform plan` has a concrete CEL example to show. Leave false otherwise —
# production grants are created dynamically by grant_access, not by Terraform.
# enable_example_jit_grant = false
# demo_loan_officer_email  = "loan.officer@example.com"
# demo_grant_expiry        = "2026-12-31T23:59:59Z"
