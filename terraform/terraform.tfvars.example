# Copy to terraform.tfvars and fill in. At minimum set project_id.
# terraform.tfvars is gitignored; never commit real project values.

project_id = "your-gcp-project-id"

# region = "us-central1"

# Both must share this domain; requester and approver are checked against it.
# allowed_domain = "lender.example.com"

# Segregation of duties (ADR-003): these two groups must be different.
# underwriter_group = "group:underwriters@lender.example.com"
# approver_group    = "group:underwriting-leads@lender.example.com"

# One object-scoped PAM entitlement is created per id here (ADR-003).
# demo_application_ids = ["APP-1001", "APP-1002"]

# max_grant_minutes    = 30   # PAM caps and expires the grant at this bound
# max_auth_age_seconds = 300  # login must be fresher than this (ADR-004)
# reconcile_schedule   = "*/15 * * * *"
